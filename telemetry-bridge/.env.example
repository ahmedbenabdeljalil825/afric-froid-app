# Supabase — use the service_role key (Dashboard → Project Settings → API).
# Never commit the real .env or expose this key in the browser.
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_secret

# MQTT broker (same URL your web app uses, e.g. wss://host:port/mqtt or mqtts://)
MQTT_BROKER_URL=wss://your-broker.example.com/mqtt
MQTT_USERNAME=
MQTT_PASSWORD=

# Optional
# BRIDGE_FLUSH_MS=10000
# BRIDGE_WIDGET_REFRESH_MS=300000
#
# Database retention/pruning (must align with `public.prune_telemetry_readings()`)
# BRIDGE_TELEMETRY_RETENTION_HOURS=168
# BRIDGE_PRUNE_INTERVAL_MS=21600000
